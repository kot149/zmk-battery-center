{
  "name": "zmk-battery-center",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "license": "MIT",
  "author": "kot149",
  "repository": "https://github.com/kot149/zmk-battery-center",
  "homepage": "https://github.com/kot149/zmk-battery-center",
  "bugs": "https://github.com/kot149/zmk-battery-center/issues",
  "scripts": {
    "dev": "bun tauri dev",
    "dev:frontend": "vite",
    "build:ui": "tsc && vite build",
    "build:app": "bun tauri build --no-bundle",
    "with:test-data": "bun scripts/with_dev_data_dir.ts",
    "test:app": "bun run build:app && bun run with:test-data bun scripts/smoke_launch_built_app.ts",
    "build": "tauri build",
    "preview": "vite preview",
    "test": "bun run test:frontend && bun run test:rust",
    "test:frontend": "bun run with:test-data vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:e2e": "bun run e2e",
    "e2e": "bun run with:test-data playwright test",
    "e2e:install": "playwright install chromium",
    "tauri": "tauri",
    "lint": "eslint . --ext ts,tsx",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "cargo-check": "(cd src-tauri && cargo check)",
    "check-versions": "bun scripts/verify_versions.ts",
    "check-licenses": "bun scripts/check_licenses.ts",
    "generate-licenses": "bun scripts/generate_licenses.ts",
    "bump-version": "bun scripts/bump_up.ts"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-log": "~2.8.0",
    "@tauri-apps/plugin-notification": "~2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-positioner": "~2.3.1",
    "@tauri-apps/plugin-store": "~2.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.6.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.3",
    "license-checker": "^25.0.1",
    "shadcn": "^4.2.0",
    "spdx-license-list": "^6.11.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "jsdom": "^29.0.2"
  }
}
